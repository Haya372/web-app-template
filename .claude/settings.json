{
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(pnpm *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git push *)",
      "Bash(git log *)",
      "Bash(git rm *)",
      "Bash(gh pr create *)"
    ],
    "deny": [
      "Bash(gh config *)",
      "Bash(gh auth *)",
      "Bash(gh secret *)",
      "Bash(gh project *)",
      "Bash(gh release *)",
      "Bash(gh repo *)",
      "Bash(gh ssh-key *)",
      "Bash(gh codespace *)",
      "Bash(pnpm install *)",
      "Bash(pnpm i *)",
      "Bash(pnpm add *)",
      "Bash(pnpm update *)",
      "Bash(pnpm up *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(yarn *)",
      "Bash(go install *)",
      "Bash(git commit * --amend *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "input=$(cat); skill=$(echo \"$input\" | jq -r '.tool_input.skill // empty'); [ \"$skill\" = \"implement-tdd\" ] || exit 0; args=$(echo \"$input\" | jq -r '.tool_input.args // empty'); layer=$(echo \"$args\" | awk '{print tolower($1)}'); mise run generate \"${layer:-all}\"",
            "timeout": 120,
            "statusMessage": "Running code generation..."
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": ["git", "gh", "docker", "pnpm", "mise", "make"],
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "api.anthropic.com"
      ]
    },
    "enableWeakerNetworkIsolation": true
  }
}
