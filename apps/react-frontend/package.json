{
  "name": "react-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "generate": "run-p generate:*",
    "generate:route": "tsr generate",
    "build": "vite build",
    "prebuild": "run-s generate typecheck",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "run-s lint:*",
    "lint:biome": "biome lint",
    "lint:knip": "knip",
    "lint-staged": "lint-staged",
    "fmt": "run-s fmt:*",
    "fmt:biome": "biome lint --write ./src",
    "fmt:knip": "knip --fix",
    "typecheck": "tsc --noEmit",
    "check": "biome check"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@repo/ui": "workspace:*",
    "@tanstack/react-router": "1.166.2",
    "i18next": "25.8.14",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.2",
    "react-i18next": "16.5.6",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.1",
    "@tanstack/react-router-devtools": "1.166.2",
    "@tanstack/router-cli": "1.166.2",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "jsdom": "28.1.0",
    "knip": "5.86.0",
    "lint-staged": "16.3.2",
    "npm-run-all2": "8.0.4",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "pnpm biome lint --write"
    ]
  }
}
